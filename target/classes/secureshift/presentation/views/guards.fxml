<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="secureshift.presentation.controllers.GuardsController"
      prefWidth="900" prefHeight="600" spacing="12"
      stylesheets="@../css/liquid-glass.css"
      style="-fx-padding: 20; -fx-background-color: #060818;">

    <Label text="Guards" styleClass="title-label"/>

    <HBox spacing="8" style="-fx-padding: 4 0;">
        <Button text="Add Guard"       onAction="#addGuard"          styleClass="btn-success"/>
        <Button text="Edit"            onAction="#editGuard"         styleClass="btn-muted"/>
        <Button text="Delete"          onAction="#deleteGuard"       styleClass="btn-danger"/>
        <Button text="Toggle Avail"    onAction="#toggleAvailability" styleClass="btn-warn"/>
        <Button text="Refresh"         onAction="#refresh"           styleClass="btn-muted"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Export CSV"  onAction="#exportCsv"  styleClass="btn-muted"/>
        <Button text="Export PDF"  onAction="#exportPdf"  styleClass="btn-muted"/>
    </HBox>

    <TableView fx:id="guardsTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId"        text="ID"        prefWidth="130"/>
            <TableColumn fx:id="colName"      text="Name"      prefWidth="180"/>
            <TableColumn fx:id="colLatitude"  text="Latitude"  prefWidth="90"/>
            <TableColumn fx:id="colLongitude" text="Longitude" prefWidth="90"/>
            <TableColumn fx:id="colAvailable" text="Available" prefWidth="90"/>
            <TableColumn fx:id="colSkills"    text="Skills"    prefWidth="250"/>
        </columns>
        <placeholder><Label text="No guards yet. Click Add Guard to get started." styleClass="subtitle-label"/></placeholder>
    </TableView>

    <Label fx:id="statusLabel" styleClass="status-label"/>
</VBox>

