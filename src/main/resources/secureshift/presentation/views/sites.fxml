<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="secureshift.presentation.controllers.SitesController"
      prefWidth="1000" prefHeight="600" spacing="12"
      stylesheets="@../css/liquid-glass.css"
      style="-fx-padding: 20; -fx-background-color: #060818;">

    <Label text="Sites" styleClass="title-label"/>

    <HBox spacing="8" style="-fx-padding: 4 0;">
        <Button text="Add Site" onAction="#addSite"   styleClass="btn-primary"/>
        <Button text="Edit"     onAction="#editSite"  styleClass="btn-muted"/>
        <Button text="Delete"   onAction="#deleteSite" styleClass="btn-danger"/>
        <Button text="Refresh"  onAction="#refresh"   styleClass="btn-muted"/>
    </HBox>

    <TableView fx:id="sitesTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId"        text="ID"        prefWidth="50"/>
            <TableColumn fx:id="colName"      text="Name"      prefWidth="180"/>
            <TableColumn fx:id="colAddress"   text="Address"   prefWidth="200"/>
            <TableColumn fx:id="colRegion"    text="Region"    prefWidth="130"/>
            <TableColumn fx:id="colLatitude"  text="Latitude"  prefWidth="90"/>
            <TableColumn fx:id="colLongitude" text="Longitude" prefWidth="90"/>
            <TableColumn fx:id="colSkills"    text="Skills"    prefWidth="200"/>
        </columns>
        <placeholder><Label text="No sites yet. Click Add Site to get started." styleClass="subtitle-label"/></placeholder>
    </TableView>

    <Label fx:id="statusLabel" styleClass="status-label"/>
</VBox>

