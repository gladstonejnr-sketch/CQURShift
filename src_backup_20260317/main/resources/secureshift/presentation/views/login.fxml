<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<StackPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
           fx:controller="secureshift.presentation.controllers.LoginController"
           prefWidth="480" prefHeight="560" style="-fx-background-color: #060818;">
    <Pane mouseTransparent="true">
        <Pane style="-fx-background-color: radial-gradient(center 30% 30%, radius 50%, #1a0533 0%, transparent 70%); -fx-background-radius: 50%;" prefWidth="400" prefHeight="400" layoutX="-60" layoutY="-80"/>
        <Pane style="-fx-background-color: radial-gradient(center 70% 70%, radius 50%, #001a3a 0%, transparent 70%); -fx-background-radius: 50%;" prefWidth="400" prefHeight="400" layoutX="140" layoutY="200"/>
    </Pane>
    <VBox alignment="CENTER" spacing="0" maxWidth="360" maxHeight="460"
          style="-fx-background-color: rgba(255,255,255,0.05); -fx-background-radius: 20; -fx-border-color: rgba(255,255,255,0.12); -fx-border-radius: 20; -fx-border-width: 1; -fx-padding: 48 40 40 40; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.6), 40, 0, 0, 8);">
        <Label text="C-QURShift" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: white; -fx-effect: dropshadow(gaussian, #7c3aed, 20, 0.4, 0, 0);"/>
        <Label text="Guard Scheduling Platform" style="-fx-font-size: 12px; -fx-text-fill: rgba(255,255,255,0.45); -fx-padding: 4 0 32 0;"/>
        <Label text="USERNAME" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: rgba(255,255,255,0.5); -fx-padding: 0 0 6 2;"/>
        <TextField fx:id="usernameField" promptText="Enter username"
                   style="-fx-background-color: rgba(255,255,255,0.07); -fx-background-radius: 10; -fx-border-color: rgba(255,255,255,0.15); -fx-border-radius: 10; -fx-border-width: 1; -fx-text-fill: white; -fx-prompt-text-fill: rgba(255,255,255,0.25); -fx-padding: 12 14; -fx-font-size: 14px;"/>
        <Region prefHeight="16"/>
        <Label text="PASSWORD" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: rgba(255,255,255,0.5); -fx-padding: 0 0 6 2;"/>
        <PasswordField fx:id="passwordField" promptText="Enter password"
                       style="-fx-background-color: rgba(255,255,255,0.07); -fx-background-radius: 10; -fx-border-color: rgba(255,255,255,0.15); -fx-border-radius: 10; -fx-border-width: 1; -fx-text-fill: white; -fx-prompt-text-fill: rgba(255,255,255,0.25); -fx-padding: 12 14; -fx-font-size: 14px;"/>
        <Region prefHeight="8"/>
        <Label fx:id="errorLabel" text="" wrapText="true" style="-fx-font-size: 12px; -fx-text-fill: #ff4d6d; -fx-padding: 4 0 0 2;" visible="false" maxWidth="280"/>
        <Region prefHeight="24"/>
        <Button fx:id="loginBtn" text="Sign In" onAction="#login" maxWidth="Infinity" prefHeight="44"
                style="-fx-background-color: linear-gradient(to right, #7c3aed, #2563eb); -fx-background-radius: 10; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(124,58,237,0.5), 12, 0, 0, 4);"/>
        <Region prefHeight="28"/>
        <Label text="Default: admin / admin123  •  manager / manager123" style="-fx-font-size: 10px; -fx-text-fill: rgba(255,255,255,0.2);"/>
        <Region prefHeight="8"/>
        <Label fx:id="versionLabel" text="" style="-fx-font-size: 10px; -fx-text-fill: rgba(255,255,255,0.15);"/>
    </VBox>
</StackPane>
